{
  "name": "stm32-learning-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config web/vite.config.ts",
    "build": "npm run validate:content && npm run typecheck && vite build --config web/vite.config.ts",
    "build:firmware": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/firmware/build-all.ps1",
    "typecheck": "tsc -p web/tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest run --config web/vitest.config.ts",
    "test:watch": "vitest --config web/vitest.config.ts",
    "test:e2e": "playwright test --config web/playwright.config.ts",
    "preview": "vite preview --config web/vite.config.ts",
    "validate:content": "tsx scripts/content-validation/validate-content.ts"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
